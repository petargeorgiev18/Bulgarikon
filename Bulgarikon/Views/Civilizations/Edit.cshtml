@using Microsoft.AspNetCore.Mvc.Rendering
@model Bulgarikon.Core.DTOs.CivilizaionDTOs.CivilizationFormDto

@{
    ViewData["Title"] = "Редакция";
    var civId = (Guid?)ViewBag.CivilizationId;
    var hasErrors = ViewData.ModelState.ErrorCount > 0;
}

<div class="era-shell">
    <div class="era-header">
        <div>
            <div class="era-kicker">Админ • Редакция</div>
            <h1 class="era-h1">Редакция на цивилизация</h1>
            <div class="era-sub">Промени данните и 1 снимка (URL).</div>
        </div>

        <div class="era-actions">
            @if (civId != null)
            {
                <a asp-action="Details" asp-route-id="@civId" class="btn btn-outline-secondary">← Детайли</a>
            }
            <a asp-action="Index" asp-route-eraId="@Model.EraId" class="btn btn-outline-secondary">Към списъка</a>
        </div>
    </div>

    <div class="card shadow-sm era-paper mt-3">
        <div class="card-body p-4">
            <form asp-action="Edit" asp-route-id="@civId" method="post" autocomplete="off">
                @Html.AntiForgeryToken()

                @if (hasErrors)
                {
                    <div asp-validation-summary="All" class="alert alert-danger py-2 mb-3"></div>
                }

                <div class="mb-3">
                    <label asp-for="Name" class="form-label fw-semibold">Име</label>
                    <input asp-for="Name" class="form-control" />
                    <span asp-validation-for="Name" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Description" class="form-label fw-semibold">Описание</label>
                    <textarea asp-for="Description" class="form-control" rows="7"></textarea>
                    <span asp-validation-for="Description" class="text-danger"></span>
                </div>

                <div class="row g-3 mb-3">
                    <div class="col-md-6">
                        <label asp-for="Type" class="form-label fw-semibold">Тип</label>
                        <select asp-for="Type" class="form-select" asp-items="(IEnumerable<SelectListItem>)ViewBag.CivilizationTypes"></select>
                        <span asp-validation-for="Type" class="text-danger"></span>
                    </div>

                    <div class="col-md-6">
                        <label asp-for="EraId" class="form-label fw-semibold">Епоха</label>
                        <select asp-for="EraId" class="form-select" asp-items="(IEnumerable<SelectListItem>)ViewBag.Eras"></select>
                        <span asp-validation-for="EraId" class="text-danger"></span>
                    </div>
                </div>

                <div class="row g-3 mb-3">
                    <div class="col-md-6">
                        <label asp-for="StartYear" class="form-label fw-semibold">Начална година</label>
                        <input asp-for="StartYear" class="form-control" />
                        <span asp-validation-for="StartYear" class="text-danger"></span>
                    </div>

                    <div class="col-md-6">
                        <label asp-for="EndYear" class="form-label fw-semibold">Крайна година</label>
                        <input asp-for="EndYear" class="form-control" />
                        <span asp-validation-for="EndYear" class="text-danger"></span>
                    </div>
                </div>

                <hr class="my-4" />

                <h5 class="mb-2">Снимка (URL)</h5>

                <div class="row g-3 align-items-end">
                    <div class="col-md-8">
                        <label asp-for="ImageUrl" class="form-label fw-semibold">Image URL (по избор)</label>
                        <input asp-for="ImageUrl" class="form-control" placeholder="https://..." id="civImageUrl" />
                        <span asp-validation-for="ImageUrl" class="text-danger"></span>
                    </div>

                    <div class="col-md-4">
                        <button type="button" class="btn btn-outline-secondary w-100" id="civClearImg">Изчисти</button>
                    </div>
                </div>

                <div class="mt-3" id="civImgPreviewWrap" hidden>
                    <img id="civImgPreview"
                         alt="preview"
                         style="width:100%; max-height:280px; object-fit:cover; border-radius:16px;" />
                </div>

                <div class="d-flex gap-2 flex-wrap mt-4">
                    <button type="submit" class="btn btn-primary px-4">Запази</button>

                    @if (civId != null)
                    {
                        <a asp-action="Details" asp-route-id="@civId" class="btn btn-outline-secondary">Откажи</a>
                    }
                    else
                    {
                        <a asp-action="Index" asp-route-eraId="@Model.EraId" class="btn btn-outline-secondary">Откажи</a>
                    }
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />

    <script>
        (function () {
            const input = document.getElementById('civImageUrl');
            const clearBtn = document.getElementById('civClearImg');
            const wrap = document.getElementById('civImgPreviewWrap');
            const img = document.getElementById('civImgPreview');

            if (!input || !wrap || !img) return;

            function refresh() {
                const u = (input.value || '').trim();
                if (!u) {
                    wrap.hidden = true;
                    img.removeAttribute('src');
                    return;
                }
                img.src = u;
                wrap.hidden = false;
            }

            input.addEventListener('input', refresh);
            clearBtn?.addEventListener('click', () => { input.value = ''; refresh(); });

            refresh();
        })();
    </script>
}