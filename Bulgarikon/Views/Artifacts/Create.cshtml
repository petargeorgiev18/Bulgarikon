@using Microsoft.AspNetCore.Mvc.Rendering
@model Bulgarikon.Core.DTOs.ArtifactDTOs.ArtifactFormDto

@{
    ViewData["Title"] = "Добави артефакт";
    var hasErrors = ViewData.ModelState.ErrorCount > 0;
}

<div class="era-shell">
    <div class="era-header">
        <div>
            <div class="era-kicker">Bulgarikon • Артефакти</div>
            <h1 class="era-h1">Добави артефакт</h1>
            <div class="era-sub">Създай артефакт и добави снимка (URL).</div>
        </div>

        <div class="era-actions">
            <a asp-action="Index" class="btn btn-outline-secondary">← Назад</a>
        </div>
    </div>

    <div class="card shadow-sm era-paper mt-3">
        <div class="card-body p-4">
            <form asp-action="Create" method="post" autocomplete="off">
                @Html.AntiForgeryToken()

                @if (hasErrors)
                {
                    <div asp-validation-summary="All" class="alert alert-danger py-2 mb-3"></div>
                }

                <div class="row g-3">
                    <div class="col-lg-8">
                        <label asp-for="Name" class="form-label fw-semibold">Име</label>
                        <input asp-for="Name" class="form-control" />
                        <span asp-validation-for="Name" class="text-danger"></span>
                    </div>

                    <div class="col-lg-4">
                        <label asp-for="DiscoveredAt" class="form-label fw-semibold">Открит на</label>
                        <input asp-for="DiscoveredAt" type="date" class="form-control" />
                        <span asp-validation-for="DiscoveredAt" class="text-danger"></span>
                    </div>

                    <div class="col-lg-4">
                        <label asp-for="EraId" class="form-label fw-semibold">Епоха</label>
                        <select asp-for="EraId" class="form-select" asp-items="(IEnumerable<SelectListItem>)ViewBag.Eras"></select>
                        <span asp-validation-for="EraId" class="text-danger"></span>
                    </div>

                    <div class="col-lg-4">
                        <label asp-for="CivilizationId" class="form-label fw-semibold">Цивилизация (по избор)</label>
                        <select asp-for="CivilizationId" class="form-select" asp-items="(IEnumerable<SelectListItem>)ViewBag.Civilizations">
                            <option value="">(няма)</option>
                        </select>
                        <span asp-validation-for="CivilizationId" class="text-danger"></span>
                    </div>

                    <div class="col-lg-4">
                        <label asp-for="Year" class="form-label fw-semibold">Година (по избор)</label>
                        <input asp-for="Year" type="number" class="form-control" />
                        <span asp-validation-for="Year" class="text-danger"></span>
                    </div>

                    <div class="col-lg-6">
                        <label asp-for="Material" class="form-label fw-semibold">Материал</label>
                        <select asp-for="Material" class="form-select" asp-items="(IEnumerable<SelectListItem>)ViewBag.Materials"></select>
                        <span asp-validation-for="Material" class="text-danger"></span>
                    </div>

                    <div class="col-lg-6">
                        <label asp-for="Location" class="form-label fw-semibold">Локация</label>
                        <input asp-for="Location" class="form-control" />
                        <span asp-validation-for="Location" class="text-danger"></span>
                    </div>

                    <div class="col-12">
                        <label asp-for="Description" class="form-label fw-semibold">Описание</label>
                        <textarea asp-for="Description" class="form-control" rows="7"></textarea>
                        <span asp-validation-for="Description" class="text-danger"></span>
                    </div>

                    <div class="col-12">
                        <label asp-for="ImageUrl" class="form-label fw-semibold">Снимка URL (по избор)</label>
                        <input asp-for="ImageUrl" class="form-control" placeholder="https://..." id="bkImgUrl" />
                        <span asp-validation-for="ImageUrl" class="text-danger"></span>

                        <div class="mt-3" id="bkImgPrevWrap" style="display:none;">
                            <img id="bkImgPrev" alt="preview" style="width:100%; max-height:320px; object-fit:cover; border-radius:14px;" />
                        </div>
                        <div class="text-muted small mt-2">По избор. Ако е празно — артефактът ще се запази без снимка.</div>
                    </div>
                </div>

                <div class="d-flex gap-2 flex-wrap mt-4">
                    <button type="submit" class="btn btn-primary px-4">Запази</button>
                    <a asp-action="Index" class="btn btn-outline-secondary">Отказ</a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        (function () {
            const input = document.getElementById('bkImgUrl');
            const wrap = document.getElementById('bkImgPrevWrap');
            const img = document.getElementById('bkImgPrev');
            if (!input || !wrap || !img) return;

            function refresh() {
                const u = (input.value || '').trim();
                if (!u) { wrap.style.display = 'none'; img.removeAttribute('src'); return; }
                img.src = u;
                wrap.style.display = '';
            }

            input.addEventListener('input', refresh);
            refresh();
        })();
    </script>
}