@model Bulgarikon.Core.DTOs.EraDTOs.EraFormDto

@{
    ViewData["Title"] = "Редакция на епоха";
    var eraId = (Guid?)ViewBag.EraId;
}

<div class="container py-4">

    <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-end gap-2 mb-3">
        <div>
            <div class="era-kicker">Админ • Редакция</div>
            <h1 class="mb-1">Редакция на епоха</h1>
            <div class="text-muted">Промени заглавие, описание, период и снимки.</div>
        </div>

        <div class="d-flex gap-2 flex-wrap">
            @if (eraId != null)
            {
                <a asp-action="Details" asp-route-id="@eraId" class="btn btn-outline-secondary">← Детайли</a>
            }
            <a asp-action="Index" class="btn btn-outline-secondary">Към списъка</a>
        </div>
    </div>

    <div class="row g-3">
        <div class="col-lg-8">
            <div class="card shadow-sm era-paper">
                <div class="card-body p-4">
                    <form asp-action="Edit" asp-route-id="@eraId" method="post" enctype="multipart/form-data" autocomplete="off">
                        @Html.AntiForgeryToken()

                        <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2 mb-3"></div>

                        <div class="mb-3">
                            <label asp-for="Name" class="form-label fw-semibold">Име на епохата</label>
                            <input asp-for="Name" class="form-control" />
                            <span asp-validation-for="Name" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Description" class="form-label fw-semibold d-flex justify-content-between">
                                <span>Описание</span>
                                <span class="text-muted small"><span id="descCount">0</span> символа</span>
                            </label>
                            <textarea asp-for="Description" class="form-control" rows="7"></textarea>
                            <span asp-validation-for="Description" class="text-danger"></span>
                        </div>

                        <div class="row g-3 mb-2">
                            <div class="col-md-6">
                                <label asp-for="StartYear" class="form-label fw-semibold">Начална година</label>
                                <input asp-for="StartYear" class="form-control" id="startYear" />
                                <span asp-validation-for="StartYear" class="text-danger"></span>
                            </div>

                            <div class="col-md-6">
                                <label asp-for="EndYear" class="form-label fw-semibold">Крайна година</label>
                                <input asp-for="EndYear" class="form-control" id="endYear" />
                                <span asp-validation-for="EndYear" class="text-danger"></span>
                            </div>
                        </div>

                        <div class="mt-4">
                            <h5 class="mb-2">Качи нови снимки от устройство</h5>
                            <div class="text-muted small mb-2">Тези снимки ще се качат в Cloudinary и ще се добавят към епохата.</div>

                            <input asp-for="ImageFiles" type="file" multiple class="form-control" />
                            <span asp-validation-for="ImageFiles" class="text-danger"></span>
                        </div>

                        <div class="mt-4">
                            <div class="d-flex align-items-center justify-content-between">
                                <h5 class="mb-0">Снимки</h5>
                                <button type="button" class="btn btn-sm btn-outline-dark" id="addEraImgBtn">+ Добави снимка</button>
                            </div>

                            <div id="eraImagesWrap" class="mt-3" style="display:grid; gap:12px;"></div>

                            <div class="text-muted small mt-2">
                                Маркирай "Премахни" за изтриване. Редактирай URL/надпис и запази.
                            </div>
                        </div>

                        <div class="d-flex gap-2 flex-wrap mt-4">
                            <button type="submit" class="btn btn-primary px-4">Запази промените</button>
                            @if (eraId != null)
                            {
                                <a asp-action="Details" asp-route-id="@eraId" class="btn btn-outline-secondary">Откажи</a>
                            }
                            else
                            {
                                <a asp-action="Index" class="btn btn-outline-secondary">Откажи</a>
                            }
                        </div>
                    </form>
                </div>
            </div>
        </div>

        <div class="col-lg-4">
            <div class="card shadow-sm era-paper">
                <div class="card-body p-4">
                    <div class="d-flex align-items-center justify-content-between mb-2">
                        <h5 class="mb-0">Преглед</h5>
                        <span class="badge text-bg-dark" id="yearsBadge">—</span>
                    </div>

                    <div class="small text-muted mb-3">Live преглед докато редактираш.</div>

                    <div class="preview-box">
                        <div class="preview-title" id="previewName">—</div>
                        <div class="preview-period" id="previewPeriod">—</div>
                        <div class="preview-desc" id="previewDesc">—</div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />

    <script>
        (function () {
            const nameEl = document.querySelector('[name="Name"]');
            const descEl = document.querySelector('[name="Description"]');
            const startEl = document.getElementById('startYear');
            const endEl = document.getElementById('endYear');

            const previewName = document.getElementById('previewName');
            const previewPeriod = document.getElementById('previewPeriod');
            const previewDesc = document.getElementById('previewDesc');
            const descCount = document.getElementById('descCount');
            const yearsBadge = document.getElementById('yearsBadge');

            function v(el) { return (el?.value || '').trim(); }

            function update() {
                const n = v(nameEl);
                const d = v(descEl);
                const s = v(startEl);
                const e = v(endEl);

                previewName.textContent = n || "Име на епохата…";
                previewDesc.textContent = d || "Описанието ще се появи тук…";
                previewPeriod.textContent = (s || e) ? `${s || "…"} – ${e || "…"}` : "Начало – Край";
                descCount.textContent = String((descEl?.value || '').length);

                const sNum = Number(s);
                const eNum = Number(e);
                if (s && e && !Number.isNaN(sNum) && !Number.isNaN(eNum)) {
                    const years = eNum - sNum + 1;
                    yearsBadge.textContent = years > 0 ? `${years} г.` : "—";
                } else {
                    yearsBadge.textContent = "—";
                }
            }

            [nameEl, descEl, startEl, endEl].forEach(x => x?.addEventListener('input', update));
            update();
        })();
    </script>

    <script>
        (function () {
            const wrap = document.getElementById('eraImagesWrap');
            const btn = document.getElementById('addEraImgBtn');
            if (!wrap || !btn) return;

            function esc(s) {
                return (s || '').replace(/[&<>"']/g, c => ({
                    '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;'
                }[c]));
            }

            function newKey() {
                return 'k' + Math.random().toString(36).slice(2) + Date.now().toString(36);
            }

            function renderRow(key, idVal, urlVal, capVal, removeVal) {
                const row = document.createElement('div');
                row.className = 'bk-imgrow';
                row.dataset.key = key;

                row.innerHTML = `
                    <input type="hidden" name="Images.Index" value="${esc(key)}" />
                    <input type="hidden" name="Images[${esc(key)}].Id" value="${esc(idVal)}" />
                    <input type="hidden" name="Images[${esc(key)}].Remove" value="${removeVal ? 'true' : 'false'}" />

                    <div class="bk-imgrow-grid">
                        <div>
                            <label class="form-label fw-semibold">URL</label>
                            <input class="form-control" name="Images[${esc(key)}].Url" value="${esc(urlVal)}" placeholder="https://..." />
                        </div>

                        <div>
                            <label class="form-label fw-semibold">Надпис (по желание)</label>
                            <input class="form-control" name="Images[${esc(key)}].Caption" value="${esc(capVal)}" placeholder="Кратък надпис..." />
                        </div>

                        <div class="bk-imgrow-actions">
                            <label class="form-label fw-semibold d-block">Действия</label>

                            <div class="d-grid gap-2">
                                <button type="button" class="btn btn-outline-danger" data-remove-btn>
                                    Премахни
                                </button>

                                <button type="button" class="btn btn-outline-secondary" data-undo-btn style="display:none;">
                                    Върни
                                </button>
                            </div>
                        </div>
                    </div>

                    <div class="bk-imgrow-preview" hidden>
                        <img alt="preview" />
                        <div class="bk-imgrow-cap"></div>
                    </div>
                `;

                const urlInput = row.querySelector(`input[name="Images[${key}].Url"]`);
                const capInput = row.querySelector(`input[name="Images[${key}].Caption"]`);
                const removeHidden = row.querySelector(`input[name="Images[${key}].Remove"]`);
                const prev = row.querySelector('.bk-imgrow-preview');
                const img = row.querySelector('img');
                const cap = row.querySelector('.bk-imgrow-cap');

                const removeBtn = row.querySelector('[data-remove-btn]');
                const undoBtn = row.querySelector('[data-undo-btn]');

                function setRemoved(isRemoved) {
                    removeHidden.value = isRemoved ? 'true' : 'false';
                    row.style.opacity = isRemoved ? '0.5' : '1';
                    row.style.filter = isRemoved ? 'grayscale(0.4)' : '';
                    removeBtn.style.display = isRemoved ? 'none' : '';
                    undoBtn.style.display = isRemoved ? '' : 'none';
                }

                function refreshPreview() {
                    const u = (urlInput?.value || '').trim();
                    const c = (capInput?.value || '').trim();

                    if (!u) { prev.hidden = true; return; }
                    img.src = u;
                    cap.textContent = c;
                    prev.hidden = false;
                }

                urlInput?.addEventListener('input', refreshPreview);
                capInput?.addEventListener('input', refreshPreview);

                removeBtn?.addEventListener('click', () => setRemoved(true));
                undoBtn?.addEventListener('click', () => setRemoved(false));

                wrap.appendChild(row);
                setRemoved(!!removeVal);
                refreshPreview();
            }

            const initial = @Html.Raw(
                            System.Text.Json.JsonSerializer.Serialize(
                                    Model.Images ?? new List<Bulgarikon.Core.DTOs.ImageDTOs.ImageEditDto>()
                            )
                    );

        initial.forEach(x => {
            const key = newKey();
            renderRow(
                key,
                x.id || x.Id || '',
                x.url || x.Url || '',
                x.caption || x.Caption || '',
                x.remove || x.Remove || false
            );
        });

            btn.addEventListener('click', () => {
                const key = newKey();
                renderRow(key, '', '', '', false);
            });
        })();
    </script>
}