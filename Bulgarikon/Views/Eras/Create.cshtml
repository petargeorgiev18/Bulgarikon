@model Bulgarikon.ViewModels.EraViewModels.EraFormViewModel

@{
    ViewData["Title"] = "Добавяне на епоха";
}

<div class="container py-4">

    <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-end gap-2 mb-3">
        <div>
            <div class="era-kicker">Админ • Историческо съдържание</div>
            <h1 class="mb-1">Добавяне на епоха</h1>
            <div class="text-muted">Създай нов период, който ще групира събития, личности и артефакти.</div>
        </div>

        <a asp-action="Index" class="btn btn-outline-secondary">← Назад</a>
    </div>

    <div class="row g-3">
        <div class="col-lg-8">
            <div class="card shadow-sm era-paper">
                <div class="card-body p-4">
                    <form asp-action="Create" method="post" enctype="multipart/form-data" autocomplete="off">
                        @Html.AntiForgeryToken()

                        <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2 mb-3"></div>

                        <div class="mb-3">
                            <label asp-for="Name" class="form-label fw-semibold">Име на епохата</label>
                            <input asp-for="Name" class="form-control" placeholder="Напр. Средновековие, Възраждане..." />
                            <div class="form-text">Кратко и ясно заглавие.</div>
                            <span asp-validation-for="Name" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Description" class="form-label fw-semibold d-flex justify-content-between">
                                <span>Описание</span>
                                <span class="text-muted small"><span id="descCount">0</span> символа</span>
                            </label>
                            <textarea asp-for="Description" class="form-control" rows="7"
                                      placeholder="Опиши какво характеризира епохата (общество, култура, ключови събития)..."></textarea>
                            <div class="form-text">Пиши ясно и информативно.</div>
                            <span asp-validation-for="Description" class="text-danger"></span>
                        </div>

                        <div class="row g-3 mb-2">
                            <div class="col-md-6">
                                <label asp-for="StartYear" class="form-label fw-semibold">Начална година</label>
                                <input asp-for="StartYear" class="form-control" id="startYear" placeholder="681" />
                                <span asp-validation-for="StartYear" class="text-danger"></span>
                            </div>

                            <div class="col-md-6">
                                <label asp-for="EndYear" class="form-label fw-semibold">Крайна година</label>
                                <input asp-for="EndYear" class="form-control" id="endYear" placeholder="1018" />
                                <span asp-validation-for="EndYear" class="text-danger"></span>
                            </div>
                        </div>

                        <div class="mt-4">
                            <h5 class="mb-2">Качи снимки от устройство</h5>
                            <div class="text-muted small mb-2">Тези снимки ще се качат в Cloudinary.</div>

                            <input asp-for="ImageFiles" type="file" multiple class="form-control" />
                            <span asp-validation-for="ImageFiles" class="text-danger"></span>
                        </div>

                        <div class="mt-4">
                            <div class="d-flex align-items-center justify-content-between">
                                <h5 class="mb-0">Снимки чрез URL (по желание)</h5>
                                <button type="button" class="btn btn-sm btn-outline-dark" id="addEraImgBtn">+ Добави снимка</button>
                            </div>

                            <div class="text-muted small mt-1">URL + надпис. Можеш да добавиш повече от една.</div>

                            <div id="eraImagesWrap" class="mt-3" style="display:grid; gap:12px;"></div>
                        </div>

                        <div class="d-flex gap-2 flex-wrap mt-4">
                            <button type="submit" class="btn btn-primary px-4">Запази</button>
                            <a asp-action="Index" class="btn btn-outline-secondary">Откажи</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>

        <div class="col-lg-4">
            <div class="card shadow-sm era-paper">
                <div class="card-body p-4">
                    <div class="d-flex align-items-center justify-content-between mb-2">
                        <h5 class="mb-0">Преглед</h5>
                        <span class="badge text-bg-dark" id="yearsBadge">—</span>
                    </div>

                    <div class="small text-muted mb-3">Как ще изглежда епохата в списъка.</div>

                    <div class="preview-box">
                        <div class="preview-title" id="previewName">Име на епохата…</div>
                        <div class="preview-period" id="previewPeriod">Начало – Край</div>
                        <div class="preview-desc" id="previewDesc">Описанието ще се появи тук…</div>
                    </div>

                    <div class="mt-3 small text-muted">
                        Съвет: 3–6 изречения, максимум 1 абзац за бързо четене.
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />

    <script>
        (function () {
            const nameEl = document.querySelector('[name="Name"]');
            const descEl = document.querySelector('[name="Description"]');
            const startEl = document.getElementById('startYear');
            const endEl = document.getElementById('endYear');

            const previewName = document.getElementById('previewName');
            const previewPeriod = document.getElementById('previewPeriod');
            const previewDesc = document.getElementById('previewDesc');
            const descCount = document.getElementById('descCount');
            const yearsBadge = document.getElementById('yearsBadge');

            function v(el) { return (el?.value || '').trim(); }

            function update() {
                const n = v(nameEl);
                const d = v(descEl);
                const s = v(startEl);
                const e = v(endEl);

                previewName.textContent = n || "Име на епохата…";
                previewDesc.textContent = d || "Описанието ще се появи тук…";
                previewPeriod.textContent = (s || e) ? `${s || "…"} – ${e || "…"}` : "Начало – Край";
                descCount.textContent = String((descEl?.value || '').length);

                const sNum = Number(s);
                const eNum = Number(e);
                if (s && e && !Number.isNaN(sNum) && !Number.isNaN(eNum)) {
                    const years = eNum - sNum + 1;
                    yearsBadge.textContent = years > 0 ? `${years} г.` : "—";
                } else {
                    yearsBadge.textContent = "—";
                }
            }

            [nameEl, descEl, startEl, endEl].forEach(x => x?.addEventListener('input', update));
            update();
        })();
    </script>

    <script>
        (function () {
            const wrap = document.getElementById('eraImagesWrap');
            const btn = document.getElementById('addEraImgBtn');
            if (!wrap || !btn) return;

            let idx = 0;

            function esc(s) {
                return (s || '').replace(/[&<>"']/g, c => ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;' }[c]));
            }

            function renderRow(i, urlVal, capVal) {
                const row = document.createElement('div');
                row.className = 'bk-imgrow';
                row.innerHTML = `
                    <div class="bk-imgrow-grid">
                        <div>
                            <label class="form-label fw-semibold">URL</label>
                            <input class="form-control" name="Images[${i}].Url" value="${esc(urlVal)}" placeholder="https://..." />
                        </div>
                        <div>
                            <label class="form-label fw-semibold">Надпис (по желание)</label>
                            <input class="form-control" name="Images[${i}].Caption" value="${esc(capVal)}" placeholder="Кратък надпис..." />
                        </div>
                        <div class="bk-imgrow-actions">
                            <label class="form-label fw-semibold d-block">Премахни</label>
                            <button type="button" class="btn btn-outline-danger w-100" data-remove>Изтрий ред</button>
                        </div>
                    </div>
                    <div class="bk-imgrow-preview" hidden>
                        <img alt="preview" />
                        <div class="bk-imgrow-cap"></div>
                    </div>
                `;

                const urlInput = row.querySelector(`input[name="Images[${i}].Url"]`);
                const capInput = row.querySelector(`input[name="Images[${i}].Caption"]`);
                const prev = row.querySelector('.bk-imgrow-preview');
                const img = row.querySelector('img');
                const cap = row.querySelector('.bk-imgrow-cap');

                function refreshPreview() {
                    const u = (urlInput?.value || '').trim();
                    const c = (capInput?.value || '').trim();
                    if (!u) { prev.hidden = true; return; }
                    img.src = u;
                    cap.textContent = c;
                    prev.hidden = false;
                }

                urlInput?.addEventListener('input', refreshPreview);
                capInput?.addEventListener('input', refreshPreview);

                row.querySelector('[data-remove]')?.addEventListener('click', () => row.remove());

                wrap.appendChild(row);
                refreshPreview();
            }

            btn.addEventListener('click', () => {
                renderRow(idx, '', '');
                idx++;
            });
        })();
    </script>
}