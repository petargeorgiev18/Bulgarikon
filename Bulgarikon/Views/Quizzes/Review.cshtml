@model Bulgarikon.Core.DTOs.QuizDTOs.QuizReviewViewDto

@{
    ViewData["Title"] = "Преглед на теста";
}

<div class="era-shell">
    <div class="era-header">
        <div>
            <div class="era-kicker">Bulgarikon • Преглед</div>
            <h1 class="era-h1">@Model.QuizTitle</h1>
        </div>

        <a asp-action="MyResults" class="bk-navbtn">← Назад</a>
    </div>

    <div class="mt-3">

        @for (int i = 0; i < Model.Questions.Count; i++)
        {
            var q = Model.Questions[i];

            <div class="card shadow-sm mb-3 era-paper" style="border-radius:16px;">
                <div class="card-body">

                    <div class="fw-bold mb-2">
                        @(i + 1). @q.QuestionText
                    </div>

                    <div class="mb-1">
                        <span class="fw-bold">Твоят отговор:</span>
                        <span class="@(q.IsCorrect ? "text-success" : "text-danger")">
                            @(q.SelectedAnswer ?? "Няма избран отговор")
                        </span>
                    </div>

                    @if (!q.IsCorrect)
                    {
                        <div>
                            <span class="fw-bold">Верният отговор:</span>
                            <span class="text-success">@q.CorrectAnswer</span>
                        </div>
                    }

                </div>
            </div>
        }

    </div>
</div>