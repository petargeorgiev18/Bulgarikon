@model Bulgarikon.Core.DTOs.QuizDTOs.QuizDetailsDto

@{
    ViewData["Title"] = "Детайли";
    bool isAdmin = User.IsInRole("Admin");
    bool disabled = Model.QuestionsCount == 0;
}

<div class="era-shell">
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-warning border-0 shadow-sm">
            @TempData["Error"]
        </div>
    }

    <div class="era-header">
        <div>
            <div class="era-kicker">Bulgarikon • Куиз</div>
            <h1 class="era-h1">@Model.Title</h1>

            <div class="era-sub">
                Епоха: <b>@Model.EraName</b> • Въпроси: <b>@Model.QuestionsCount</b>

                @if (disabled)
                {
                    <span class="ms-2 text-muted small">
                        Няма въпроси – куизът още не е готов.
                    </span>
                }
            </div>
        </div>

        <div class="era-actions d-flex gap-2 flex-wrap">
            <a asp-action="Index" class="btn btn-outline-secondary">
                ← Назад
            </a>

            @if (!isAdmin)
            {
                <a asp-action="Take"
                   asp-route-id="@Model.Id"
                   class="btn btn-primary @(disabled ? "disabled" : "")"
                   aria-disabled="@(disabled ? "true" : "false")"
                   style="@(disabled ? "pointer-events:none; opacity:.6;" : "")">
                    Започни
                </a>
            }

            @if (isAdmin)
            {
                <a asp-controller="Questions"
                   asp-action="Index"
                   asp-route-quizId="@Model.Id"
                   class="btn btn-outline-primary">
                    Управлявай въпроси
                </a>

                <a asp-action="Edit"
                   asp-route-id="@Model.Id"
                   class="btn btn-outline-primary">
                    Редакция
                </a>

                <form asp-action="Delete" method="post" class="d-inline">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="id" value="@Model.Id" />
                    <button type="submit" class="btn btn-outline-danger">
                        Изтрий
                    </button>
                </form>
            }
        </div>
    </div>

    <div class="card shadow-sm">
        <div class="card-body">
            <div class="d-flex flex-wrap gap-2">
                <span class="era-chip">Епоха: @Model.EraName</span>
                <span class="era-chip">Въпроси: @Model.QuestionsCount</span>
            </div>

            @if (!isAdmin && !disabled)
            {
                <div class="alert alert-info mt-3 mb-0">
                    Съвет: чети внимателно условието — често 1–2 думи решават въпроса.
                </div>
            }
        </div>
    </div>
</div>