@model Bulgarikon.Core.DTOs.QuizDTOs.QuizTakeDto

@{
    ViewData["Title"] = "Куиз";
    var total = Model.Questions?.Count ?? 0;
}

<div class="era-shell">
    <div class="era-header">
        <div>
            <div class="era-kicker">Bulgarikon • Куиз</div>
            <h1 class="era-h1">@Model.Title</h1>
            <div class="era-sub">
                <span class="era-chip">Епоха: @Model.EraName</span>
                <span class="era-chip">Въпроси: @total</span>
            </div>
        </div>

        <div class="era-actions">
            <a asp-action="Details" asp-route-id="@Model.QuizId" class="bk-navbtn">← Назад</a>
        </div>
    </div>

    <form asp-action="Submit" method="post" class="mt-3">
        @Html.AntiForgeryToken()
        <input type="hidden" name="QuizId" value="@Model.QuizId" />

        @for (int i = 0; i < total; i++)
        {
            var q = Model.Questions[i];

            <div class="card shadow-sm mb-3 era-paper" style="border-radius:16px;">
                <div class="card-body">
                    <div class="d-flex align-items-start justify-content-between gap-2 flex-wrap">
                        <div>
                            <div class="era-kicker">Въпрос @(i + 1) / @total</div>
                            <div class="era-title mt-1" style="font-size:1.05rem;">@q.Text</div>
                        </div>
                        <span class="era-chip">Избери 1 отговор</span>
                    </div>

                    <div class="mt-3" style="display:grid; gap:10px;">
                        @foreach (var a in q.Answers)
                        {
                            var inputId = $"q_{q.QuestionId}__a_{a.AnswerId}";

                            <label for="@inputId"
                                   class="bk-card"
                                   style="cursor:pointer; border-radius:14px; padding:12px 14px;">
                                <div class="d-flex align-items-start gap-2">
                                    <input class="form-check-input m-0 mt-1"
                                           type="radio"
                                           name="Answers[@q.QuestionId]"
                                           value="@a.AnswerId"
                                           id="@inputId"
                                           required />
                                    <div>
                                        <div style="line-height:1.25;">@a.Text</div>
                                    </div>
                                </div>
                            </label>
                        }
                    </div>
                </div>
            </div>
        }

        <div class="d-flex justify-content-end gap-2 flex-wrap">
            <a asp-action="Details" asp-route-id="@Model.QuizId" class="bk-navbtn">Отказ</a>
            <button type="submit" class="bk-navbtn bk-navbtn-primary">Предай</button>
        </div>
    </form>
</div>