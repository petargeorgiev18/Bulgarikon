@model Bulgarikon.ViewModels.QuizViewModels.QuizResultViewViewModel

@{
    ViewData["Title"] = "Резултат";

    var max = Model.MaxScore <= 0 ? 1 : Model.MaxScore;
    var percent = (int)Math.Round((Model.Score * 100.0) / max);

    string gradeText =
        percent >= 90 ? "Отличен" :
        percent >= 70 ? "Много добър" :
        percent >= 50 ? "Добър" :
        percent >= 30 ? "Среден" :
        "Слаб";

    string gradeHint =
        percent >= 90 ? "Браво! Много стабилно." :
        percent >= 70 ? "Супер! Още малко и си топ." :
        percent >= 50 ? "Добре е — пробвай пак за по-високо." :
        percent >= 30 ? "Имаш база — преговори и опитай отново." :
        "Спокойно — преговори и натискай пак.";
}

<div class="era-shell">
    <div class="era-header">
        <div>
            <div class="era-kicker">Bulgarikon • Резултат</div>
            <h1 class="era-h1">@Model.QuizTitle</h1>
            <div class="era-sub">
                <span class="era-chip">Епоха: @Model.EraName</span>
                <span class="era-chip">@Model.DateTaken.ToString("dd.MM.yyyy HH:mm")</span>
            </div>
        </div>

        <div class="era-actions">
            <a asp-action="Index" class="bk-navbtn">← Всички куизове</a>
        </div>
    </div>

    <div class="card shadow-sm era-paper mt-3" style="border-radius:16px;">
        <div class="card-body">
            <div class="d-flex flex-column flex-lg-row justify-content-between gap-3">
                <div style="min-width:260px;">
                    <div class="era-kicker">Твоят резултат</div>
                    <div class="era-title" style="font-size:1.6rem; font-weight:800;">
                        @Model.Score / @Model.MaxScore
                    </div>
                    <div class="text-muted mt-1">
                        @gradeText • <b>@percent%</b>
                    </div>

                    <div class="mt-3">
                        <div class="era-kicker">Напредък</div>
                        <div class="progress mt-1" style="height:12px;">
                            <div class="progress-bar"
                                 role="progressbar"
                                 style="width:@percent%;"
                                 aria-valuenow="@percent" aria-valuemin="0" aria-valuemax="100"></div>
                        </div>
                    </div>
                </div>

                <div class="bk-card" style="border-radius:16px; flex:1;">
                    <div class="bk-card-title">@gradeText</div>
                    <div class="bk-card-sub">@gradeHint</div>
                </div>
            </div>

            <div class="d-flex gap-2 flex-wrap mt-3">
                <a asp-action="Details" asp-route-id="@Model.QuizId" class="bk-navbtn">Към куиза</a>
                <a asp-action="Take" asp-route-id="@Model.QuizId" class="bk-navbtn bk-navbtn-primary">Опитай пак</a>
                <a asp-action="MyResults" class="bk-navbtn">Моите резултати</a>
            </div>
        </div>
    </div>
</div>