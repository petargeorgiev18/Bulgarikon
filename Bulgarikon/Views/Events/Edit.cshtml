@model Bulgarikon.ViewModels.EventViewModels.EventFormViewModel
@using Microsoft.AspNetCore.Mvc.Rendering

@{
    ViewData["Title"] = "Редакция";
    var id = (Guid)ViewBag.EventId;
}

<div class="container py-3">
    <div class="d-flex align-items-center justify-content-between gap-2 mb-3">
        <div>
            <div class="text-muted small">Събития</div>
            <h1 class="mb-0">Редакция</h1>
        </div>
        <a asp-action="Details" asp-route-id="@id" class="btn btn-outline-secondary">← Назад</a>
    </div>

    <div class="card shadow-sm">
        <div class="card-body">
            <form asp-action="Edit" asp-route-id="@id" method="post" enctype="multipart/form-data" autocomplete="off">
                @Html.AntiForgeryToken()

                <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2 mb-3"></div>

                <div class="row g-3">
                    <div class="col-lg-8">
                        <label class="form-label">Заглавие</label>
                        <input asp-for="Title" class="form-control" />
                        <span asp-validation-for="Title" class="text-danger"></span>
                    </div>

                    <div class="col-lg-4">
                        <label class="form-label">Епоха</label>
                        <select asp-for="EraId" class="form-select"
                                asp-items="(IEnumerable<SelectListItem>)ViewBag.Eras"></select>
                        <span asp-validation-for="EraId" class="text-danger"></span>
                    </div>

                    <div class="col-lg-6">
                        <label class="form-label">Начална година</label>
                        <input asp-for="StartYear" class="form-control" type="number" />
                        <span asp-validation-for="StartYear" class="text-danger"></span>
                    </div>

                    <div class="col-lg-6">
                        <label class="form-label">Крайна година</label>
                        <input asp-for="EndYear" class="form-control" type="number" />
                        <span asp-validation-for="EndYear" class="text-danger"></span>
                    </div>

                    <div class="col-12">
                        <label class="form-label">Локация (по желание)</label>
                        <input asp-for="Location" class="form-control" />
                        <span asp-validation-for="Location" class="text-danger"></span>
                    </div>

                    <div class="col-12">
                        <label class="form-label">Описание</label>
                        <textarea asp-for="Description" class="form-control" rows="6"></textarea>
                        <span asp-validation-for="Description" class="text-danger"></span>
                    </div>

                    <div class="col-lg-6">
                        <label class="form-label">Цивилизации (по желание)</label>
                        <select asp-for="CivilizationIds" class="form-select" multiple
                                asp-items="(IEnumerable<SelectListItem>)ViewBag.Civilizations"></select>
                    </div>

                    <div class="col-lg-6">
                        <label class="form-label">Личности (по желание)</label>
                        <select asp-for="FigureIds" class="form-select" multiple
                                asp-items="(IEnumerable<SelectListItem>)ViewBag.Figures"></select>
                    </div>

                    <div class="col-12">
                        <label asp-for="ImageFiles" class="form-label fw-semibold">Качи нови снимки (по избор)</label>
                        <input asp-for="ImageFiles" type="file" multiple class="form-control" accept="image/*" />
                        <span asp-validation-for="ImageFiles" class="text-danger"></span>
                        <div class="text-muted small mt-2">Новите файлове ще се добавят към галерията.</div>
                    </div>
                </div>

                <hr class="my-4" />

                <div class="d-flex align-items-center justify-content-between">
                    <h5 class="mb-0">Снимки</h5>
                    <button type="button" class="btn btn-sm btn-outline-dark" id="addEventImgBtn">+ Добави снимка</button>
                </div>

                <div id="eventImagesWrap" class="mt-3" style="display:grid; gap:12px;"></div>

                <div class="text-muted small mt-2">
                    Натисни "Премахни" за изтриване. Редактирай URL/надпис и запази.
                </div>

                <div class="d-flex justify-content-end gap-2 mt-4">
                    <a asp-action="Details" asp-route-id="@id" class="btn btn-outline-secondary">Отказ</a>
                    <button type="submit" class="btn btn-primary">Запази</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />

    <script>
        (function () {
            const wrap = document.getElementById('eventImagesWrap');
            const btn = document.getElementById('addEventImgBtn');
            if (!wrap || !btn) return;

            function esc(s) {
                return (s || '').toString().replace(/[&<>"']/g, c => ({
                    '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;'
                }[c]));
            }

            function newKey() {
                return 'k' + Math.random().toString(36).slice(2) + Date.now().toString(36);
            }

            function renderRow(key, idVal, urlVal, capVal, removeVal) {
                const row = document.createElement('div');
                row.className = 'bk-imgrow';
                row.dataset.key = key;

                row.innerHTML = `
                    <input type="hidden" name="Images.Index" value="${esc(key)}" />
                    <input type="hidden" name="Images[${esc(key)}].Id" value="${esc(idVal)}" />
                    <input type="hidden" name="Images[${esc(key)}].Remove" value="${removeVal ? 'true' : 'false'}" />

                    <div class="bk-imgrow-grid">
                        <div>
                            <label class="form-label fw-semibold">URL</label>
                            <input class="form-control" name="Images[${esc(key)}].Url" value="${esc(urlVal)}" placeholder="https://..." />
                        </div>

                        <div>
                            <label class="form-label fw-semibold">Надпис (по желание)</label>
                            <input class="form-control" name="Images[${esc(key)}].Caption" value="${esc(capVal)}" placeholder="Кратък надпис..." />
                        </div>

                        <div class="bk-imgrow-actions">
                            <label class="form-label fw-semibold d-block">Действия</label>
                            <div class="d-grid gap-2">
                                <button type="button" class="btn btn-outline-danger" data-remove-btn>Премахни</button>
                                <button type="button" class="btn btn-outline-secondary" data-undo-btn style="display:none;">Върни</button>
                            </div>
                        </div>
                    </div>

                    <div class="bk-imgrow-preview" hidden>
                        <img alt="preview" />
                        <div class="bk-imgrow-cap"></div>
                    </div>
                `;

                const urlInput = row.querySelector(`input[name="Images[${key}].Url"]`);
                const capInput = row.querySelector(`input[name="Images[${key}].Caption"]`);
                const removeHidden = row.querySelector(`input[name="Images[${key}].Remove"]`);

                const prev = row.querySelector('.bk-imgrow-preview');
                const img = row.querySelector('img');
                const cap = row.querySelector('.bk-imgrow-cap');

                const removeBtn = row.querySelector('[data-remove-btn]');
                const undoBtn = row.querySelector('[data-undo-btn]');

                function setRemoved(isRemoved) {
                    removeHidden.value = isRemoved ? 'true' : 'false';
                    row.style.opacity = isRemoved ? '0.5' : '1';
                    row.style.filter = isRemoved ? 'grayscale(0.35)' : '';
                    removeBtn.style.display = isRemoved ? 'none' : '';
                    undoBtn.style.display = isRemoved ? '' : 'none';
                }

                function refreshPreview() {
                    const u = (urlInput?.value || '').trim();
                    const c = (capInput?.value || '').trim();

                    if (!u) { prev.hidden = true; return; }
                    img.src = u;
                    cap.textContent = c;
                    prev.hidden = false;
                }

                urlInput?.addEventListener('input', refreshPreview);
                capInput?.addEventListener('input', refreshPreview);

                removeBtn?.addEventListener('click', () => setRemoved(true));
                undoBtn?.addEventListener('click', () => setRemoved(false));

                wrap.appendChild(row);
                setRemoved(!!removeVal);
                refreshPreview();
            }

            const initial = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(
                            Model.Images ?? new List<Bulgarikon.ViewModels.ImageViewModels.ImageEditViewModel>()
                    ));

        if (initial && initial.length) {
            initial.forEach(x => {
                const key = newKey();
                renderRow(
                    key,
                    x.id || x.Id || '',
                    x.url || x.Url || '',
                    x.caption || x.Caption || '',
                    x.remove || x.Remove || false
                );
            });
        } else {
            const key = newKey();
            renderRow(key, '', '', '', false);
        }

            btn.addEventListener('click', () => {
                const key = newKey();
                renderRow(key, '', '', '', false);
            });
        })();
    </script>
}